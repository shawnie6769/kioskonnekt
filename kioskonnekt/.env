# KiosKonnekt Environment Configuration
# Copy this file to .env and fill in your actual values

# Server
PORT=3000
NODE_ENV=development

# Supabase Configuration
# Get these from your Supabase project dashboard → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key-here
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Optional: OpenAI for real AI responses (leave blank to use simulated AI)
OPENAI_API_KEY=

# Admin credentials (change in production!)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=kioskonnekt2025

# File upload settings
MAX_FILE_SIZE_MB=10
UPLOAD_DIR=./public/uploads

# n8n configuration
N8N_HOST=http://localhost:5678
N8N_WEBHOOK_URL=http://localhost:5678/webhook-test/applicant-interview